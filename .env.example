# Proveedor de correo para el formulario de contacto de /about
EMAIL_PROVIDER=resend        # "resend" | "gmail"

# Destinatario de los mensajes de contacto (aplica a ambos proveedores)
CONTACT_TO_EMAIL=team@arcadevault.example

# Resend — usado si EMAIL_PROVIDER=resend
RESEND_API_KEY=

# Gmail API — usado si EMAIL_PROVIDER=gmail (OAuth2 con refresh token)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER_EMAIL=
